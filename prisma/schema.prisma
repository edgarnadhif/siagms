generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  users           User[]
  companyProfile  CompanyProfile?
  companySettings CompanySettings?
  projects        Project[]
  accounts        Account[]
  transactions    Transaction[]
  journals        Journal[]
  journalEntries  JournalEntry[]
  customers       Customer[]
  units           Unit[]
  unitAkads       UnitAkad[]
  serahTerimas    SerahTerima[]
  cancellations   Cancellation[]
  calendarEvents  CalendarEvent[]
}

enum Role {
  SUPER_ADMIN
  AKUNTAN
  MARKETING
}

model User {
  id             Int             @id @default(autoincrement())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email          String
  password       String
  fullName       String?
  role           Role            @default(MARKETING)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  calendarEvents CalendarEvent[]

  @@unique([tenantId, email])
  @@index([tenantId, role])
}

model CompanyProfile {
  id        Int      @id @default(autoincrement())
  tenantId  String   @unique
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String   @default("SIAGMS")
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  updatedAt DateTime @updatedAt
}

model CompanySettings {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyName    String   @default("Nama Perusahaan")
  companyAddress String?
  companyPhone   String?
  companyEmail   String?
  logoUrl        String?
  updatedAt      DateTime @updatedAt
}

enum ProjectStatus {
  AKTIF
  SELESAI
  BATAL
  TERJUAL
}

model Project {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code         String
  name         String
  description  String?
  location     String?
  startDate    DateTime?
  endDate      DateTime?
  status       ProjectStatus @default(AKTIF)
  budget       Decimal       @default(0)
  handoverDate DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  units        Unit[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

enum AccountType {
  ASET
  KEWAJIBAN
  EKUITAS
  PENDAPATAN
  BEBAN
}

enum NormalBalance {
  DEBIT
  KREDIT
}

model Account {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code           String
  name           String
  type           AccountType
  normalBalance  NormalBalance
  description    String?
  isActive       Boolean        @default(true)
  parentId       String?
  parent         Account?       @relation("SubAccount", fields: [parentId], references: [id])
  children       Account[]      @relation("SubAccount")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  journalEntries JournalEntry[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

enum TransactionCategory {
  BOOKING_FEE
  DOWN_PAYMENT
  ANGSURAN_KPR
  PELUNASAN_CASH
  PENCAIRAN_KPR
  BIAYA_KONSTRUKSI
  BIAYA_MARKETING
  BIAYA_OPERASIONAL
  BIAYA_GAJI
  LAIN_LAIN
}

enum SkemaPembayaran {
  cash
  kpr
}

enum SumberPembayaran {
  pembeli
  bank_kpr
}

enum StatusPengakuan {
  diterima
  diakui
}

model Transaction {
  id                String              @id @default(cuid())
  tenantId          String
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reference         String
  date              DateTime
  description       String
  note              String?
  category          TransactionCategory
  amount            Decimal
  projectId         String?
  project           Project?            @relation(fields: [projectId], references: [id])
  skema_pembayaran  SkemaPembayaran     @default(cash)
  sumber_pembayaran SumberPembayaran    @default(pembeli)
  status_pengakuan  StatusPengakuan     @default(diterima)
  unitId            String?
  unit              Unit?               @relation(fields: [unitId], references: [id])
  customerId        String?
  customer          Customer?           @relation(fields: [customerId], references: [id])
  kwitansiNo        String?
  kwitansiDate      DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  journalEntries    JournalEntry[]

  @@unique([tenantId, reference])
  @@unique([tenantId, kwitansiNo])
  @@index([tenantId, date])
  @@index([tenantId, category])
  @@index([tenantId, kwitansiNo])
}

model Journal {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  referenceNo String
  description String
  date        DateTime
  createdAt   DateTime       @default(now())
  entries     JournalEntry[]

  @@unique([tenantId, referenceNo])
  @@index([tenantId, date])
}

model JournalEntry {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalId     String?
  journal       Journal?     @relation(fields: [journalId], references: [id], onDelete: Cascade)
  reference     String
  date          DateTime
  description   String?
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account      @relation(fields: [accountId], references: [id])
  unitId        String?
  unit          Unit?        @relation(fields: [unitId], references: [id])
  debit         Decimal      @default(0)
  credit        Decimal      @default(0)
  createdAt     DateTime     @default(now())
  isAuto        Boolean      @default(false)

  @@index([tenantId, date])
  @@index([tenantId, reference])
  @@index([tenantId, journalId])
}

enum PaymentMethod {
  KPR
  CASH
}

enum UnitStatus {
  TERSEDIA
  BOOKING
  INDENT
  AKAD
  LUNAS
  SERAH_TERIMA
}

model Customer {
  id            String        @id @default(cuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerCode  String
  name          String
  nik           String
  phone         String
  email         String?
  address       String
  paymentMethod PaymentMethod
  bankName      String?
  kprAccountNo  String?
  kprAmount     Decimal?
  kprTenor      Int?
  kprAkadDate   DateTime?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  unit          Unit?
  transactions  Transaction[]
  serahTerimas  SerahTerima[]
  unitAkads     UnitAkad[]

  @@unique([tenantId, customerCode])
  @@unique([tenantId, nik])
  @@index([tenantId, isActive])
}

model Unit {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitCode       String
  blockName      String
  unitNumber     String
  type           String
  landArea       Decimal
  buildingArea   Decimal
  price          Decimal
  status         UnitStatus     @default(TERSEDIA)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  projectId      String
  project        Project        @relation(fields: [projectId], references: [id])
  customerId     String?        @unique
  customer       Customer?      @relation(fields: [customerId], references: [id])
  transactions   Transaction[]
  serahTerimas   SerahTerima[]
  journalEntries JournalEntry[]
  cancellations  Cancellation[]
  akadRecords    UnitAkad[]

  @@unique([tenantId, unitCode])
  @@index([tenantId, status])
  @@index([tenantId, projectId])
}

model SerahTerima {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId     String
  unit       Unit     @relation(fields: [unitId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  date       DateTime
  handoverNo String
  notes      String?
  createdAt  DateTime @default(now())
}

model Cancellation {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId        String
  unit          Unit     @relation(fields: [unitId], references: [id])
  customerId    String
  customerName  String
  customerCode  String
  tanggalBatal  DateTime
  alasan        String
  totalBFHangus Decimal  @default(0)
  createdAt     DateTime @default(now())

  @@index([tenantId, unitId])
}

model UnitAkad {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tanggalAkad DateTime
  namaBank    String
  nomorAkad   String
  nilaiKPR    Decimal
  catatan     String?
  createdAt   DateTime @default(now())

  @@unique([tenantId, nomorAkad])
  @@index([tenantId, unitId])
  @@index([tenantId, customerId])
}

enum EventType {
  AUTO
  MANUAL
}

enum EventStatus {
  PENDING
  DONE
  OVERDUE
}

model CalendarEvent {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  type        EventType   @default(MANUAL)
  status      EventStatus @default(PENDING)
  isLocked    Boolean     @default(false)
  createdBy   Int
  user        User        @relation(fields: [createdBy], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([tenantId, date])
  @@index([tenantId, createdBy])
}
