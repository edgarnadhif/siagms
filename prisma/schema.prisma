generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  accounts        Account[]
  calendarEvents  CalendarEvent[]
  cancellations   Cancellation[]
  companyProfile  CompanyProfile?
  companySettings CompanySettings?
  customers       Customer[]
  journals        Journal[]
  journalEntries  JournalEntry[]
  journalMappings JournalMapping[]
  projects        Project[]
  serahTerimas    SerahTerima[]
  transactions    Transaction[]
  units           Unit[]
  unitAkads       UnitAkad[]
  users           User[]
}

model User {
  id             Int             @id @default(autoincrement())
  email          String
  password       String
  createdAt      DateTime        @default(now())
  role           Role            @default(AKUNTAN)
  tenantId       String
  fullName       String?
  isActive       Boolean         @default(true)
  updatedAt      DateTime        @updatedAt
  calendarEvents CalendarEvent[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId, role])
}

model CompanyProfile {
  id        Int      @id @default(autoincrement())
  name      String   @default("SIAGMS")
  address   String?
  phone     String?
  email     String?
  logoUrl   String?
  updatedAt DateTime @updatedAt
  tenantId  String   @unique
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model CompanySettings {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  companyName    String   @default("Nama Perusahaan")
  companyAddress String?
  companyPhone   String?
  companyEmail   String?
  logoUrl        String?
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Project {
  id             String         @id @default(cuid())
  code           String
  name           String
  description    String?
  location       String?
  startDate      DateTime?
  status         ProjectStatus  @default(AKTIF)
  budget         Decimal        @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  endDate        DateTime?
  handoverDate   DateTime?
  tenantId       String
  journalEntries JournalEntry[]
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions   Transaction[]
  units          Unit[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model Account {
  id             String           @id @default(cuid())
  code           String
  name           String
  type           AccountType
  normalBalance  NormalBalance
  description    String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  parentId       String?
  tenantId       String
  isSystem       Boolean          @default(false)
  parent         Account?         @relation("SubAccount", fields: [parentId], references: [id])
  children       Account[]        @relation("SubAccount")
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]
  creditMappings JournalMapping[] @relation("CreditMapping")
  debitMappings  JournalMapping[] @relation("DebitMapping")

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model Transaction {
  id                String              @id @default(cuid())
  reference         String
  date              DateTime
  description       String
  note              String?
  category          TransactionCategory
  amount            Decimal
  projectId         String?
  evidenceUrl       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  skema_pembayaran  SkemaPembayaran     @default(cash)
  status_pengakuan  StatusPengakuan     @default(diterima)
  sumber_pembayaran SumberPembayaran    @default(pembeli)
  customerId        String?
  unitId            String?
  tenantId          String
  kwitansiNo        String?
  kwitansiDate      DateTime?
  journalEntries    JournalEntry[]
  customer          Customer?           @relation(fields: [customerId], references: [id])
  project           Project?            @relation(fields: [projectId], references: [id])
  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit              Unit?               @relation(fields: [unitId], references: [id])

  @@unique([tenantId, reference])
  @@unique([tenantId, kwitansiNo])
  @@index([tenantId, date])
  @@index([tenantId, category])
  @@index([tenantId, kwitansiNo])
}

model Journal {
  id          String         @id @default(cuid())
  tenantId    String
  referenceNo String
  description String
  date        DateTime
  createdAt   DateTime       @default(now())
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entries     JournalEntry[]

  @@unique([tenantId, referenceNo])
  @@index([tenantId, date])
}

model JournalEntry {
  id            String       @id @default(cuid())
  reference     String
  date          DateTime
  description   String?
  transactionId String?
  accountId     String
  debit         Decimal      @default(0)
  credit        Decimal      @default(0)
  createdAt     DateTime     @default(now())
  isAuto        Boolean      @default(false)
  unitId        String?
  tenantId      String
  journalId     String?
  projectId     String?
  account       Account      @relation(fields: [accountId], references: [id])
  journal       Journal?     @relation(fields: [journalId], references: [id], onDelete: Cascade)
  project       Project?     @relation(fields: [projectId], references: [id])
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  unit          Unit?        @relation(fields: [unitId], references: [id])

  @@index([tenantId, date])
  @@index([tenantId, reference])
  @@index([tenantId, journalId])
  @@index([tenantId, projectId])
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  phone         String
  email         String?
  address       String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bankName      String?
  customerCode  String
  isActive      Boolean       @default(true)
  kprAccountNo  String?
  kprAkadDate   DateTime?
  kprAmount     Decimal?
  kprTenor      Int?
  nik           String
  paymentMethod PaymentMethod
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  serahTerimas  SerahTerima[]
  transactions  Transaction[]
  unit          Unit?
  unitAkads     UnitAkad[]

  @@unique([tenantId, customerCode])
  @@unique([tenantId, nik])
  @@index([tenantId, isActive])
}

model Unit {
  id             String         @id @default(cuid())
  unitCode       String
  blockName      String
  unitNumber     String
  type           String
  landArea       Decimal
  buildingArea   Decimal
  price          Decimal
  status         UnitStatus     @default(TERSEDIA)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  projectId      String
  customerId     String?        @unique
  tenantId       String
  cancellations  Cancellation[]
  journalEntries JournalEntry[]
  serahTerimas   SerahTerima[]
  transactions   Transaction[]
  customer       Customer?      @relation(fields: [customerId], references: [id])
  project        Project        @relation(fields: [projectId], references: [id])
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  akadRecords    UnitAkad[]

  @@unique([tenantId, unitCode])
  @@index([tenantId, status])
  @@index([tenantId, projectId])
}

model SerahTerima {
  id         String   @id @default(cuid())
  unitId     String
  customerId String
  createdAt  DateTime @default(now())
  date       DateTime
  handoverNo String
  notes      String?
  tenantId   String
  customer   Customer @relation(fields: [customerId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit       Unit     @relation(fields: [unitId], references: [id])
}

model Cancellation {
  id            String   @id @default(cuid())
  unitId        String
  customerId    String
  customerName  String
  customerCode  String
  tanggalBatal  DateTime
  alasan        String
  totalBFHangus Decimal  @default(0)
  createdAt     DateTime @default(now())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit          Unit     @relation(fields: [unitId], references: [id])

  @@index([tenantId, unitId])
}

model UnitAkad {
  id          String   @id @default(cuid())
  tenantId    String
  unitId      String
  customerId  String
  tanggalAkad DateTime
  namaBank    String
  nomorAkad   String
  nilaiKPR    Decimal
  catatan     String?
  createdAt   DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([tenantId, nomorAkad])
  @@index([tenantId, unitId])
  @@index([tenantId, customerId])
}

model CalendarEvent {
  id          String      @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  type        EventType   @default(MANUAL)
  status      EventStatus @default(PENDING)
  isLocked    Boolean     @default(false)
  createdBy   Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenantId    String
  user        User        @relation(fields: [createdBy], references: [id])
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, date])
  @@index([tenantId, createdBy])
}

model JournalMapping {
  id              String   @id @default(cuid())
  tenantId        String
  category        String
  description     String
  debitAccountId  String
  creditAccountId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isActive        Boolean  @default(true)
  creditAccount   Account  @relation("CreditMapping", fields: [creditAccountId], references: [id])
  debitAccount    Account  @relation("DebitMapping", fields: [debitAccountId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, category])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

enum Role {
  ADMIN
  AKUNTAN
}

enum ProjectStatus {
  AKTIF
  SELESAI
  BATAL
  TERJUAL
}

enum AccountType {
  ASET
  KEWAJIBAN
  EKUITAS
  PENDAPATAN
  BEBAN
}

enum NormalBalance {
  DEBIT
  KREDIT
}

enum TransactionCategory {
  BOOKING_FEE
  DOWN_PAYMENT
  ANGSURAN_KPR
  PELUNASAN_CASH
  PENCAIRAN_KPR
  BIAYA_KONSTRUKSI
  BIAYA_MARKETING
  BIAYA_OPERASIONAL
  BIAYA_GAJI
  LAIN_LAIN
}

enum SkemaPembayaran {
  cash
  kpr
}

enum SumberPembayaran {
  pembeli
  bank_kpr
}

enum StatusPengakuan {
  diterima
  diakui
}

enum PaymentMethod {
  KPR
  CASH
}

enum UnitStatus {
  TERSEDIA
  BOOKING
  INDENT
  AKAD
  LUNAS
  SERAH_TERIMA
}

enum EventType {
  AUTO
  MANUAL
}

enum EventStatus {
  PENDING
  DONE
  OVERDUE
}
